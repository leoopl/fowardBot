API_ID=
API_HASH=
LOG_LEVEL=INFO
# Where the bot reads commands and sends forwards.
# "me" = your Saved Messages (default). Set to a numeric chat id such as
# -100**** to use a dedicated private channel/group instead.
# Discover the id by sending /chatid in that chat.
CONTROL_CHAT=me
# Seconds between history polls of each watched chat (lower = faster, more API calls).
POLL_INTERVAL=45
# Optional: BotFather token. A userbot's own forwards never notify you, so set
# this to a bot you created and added as ADMIN to your CONTROL_CHAT, and the bot
# posts a "🔔 <keyword>" alert after each match — which DOES notify you.
# Leave empty to disable notifications. (Only works when CONTROL_CHAT is a
# channel/group, not "me".)
NOTIFY_BOT_TOKEN=
# Set to 1 to log every message the live handler receives (debugging only).
DIAG=
